{
  "name": "NW_CAPM",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "private": true,
  "dependencies": {
    "@sap-cloud-sdk/connectivity": "^4.5.1",
    "@sap-cloud-sdk/http-client": "^4.5.1",
    "@sap-cloud-sdk/resilience": "^4.0.0",
    "@sap/cds": "^9",
    "@sap/xsenv": "^6.1.0",
    "@sap/xssec": "^4.13.0",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "rimraf": "^5.0.5",
    "mbt": "^1.2.29"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-nw_ui": "cds watch --open com.northwindui.nwui/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy NW_CAPM --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "watch-nw_ui1": "cds watch --open com.northui.nwui1/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-lrp_uicapm": "cds watch --open com.capmlr.lrpuicapm/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "cds": {
    "requires": {
      "destinations": true,
      "html5-repo": true,
      "northwind": {
        "kind": "odata-v2",
        "model": "srv/external/northwind",
        "credentials": {
          "destination": "Northwind"
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/lrp_uicapm"
  ]
}
